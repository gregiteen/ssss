{
  "name": "@gregiteen/ssss-cli",
  "version": "0.9.0",
  "description": "CLI tools and the reference engine for the Structured Semantic Syntax System",
  "main": "src/engine.mjs",
  "exports": {
    ".": "./src/engine.mjs",
    "./engine": "./src/engine.mjs",
    "./runtime": "./src/runtime.mjs",
    "./registry": "./src/registry.mjs",
    "./frontmatter": "./src/frontmatter.mjs",
    "./bundle": "./src/bundle.mjs",
    "./semantic": "./src/semantic.mjs",
    "./primitive": "./src/primitive.mjs",
    "./validator": "./src/validator.mjs",
    "./kernel": {
      "types": "./types/kernel.d.ts",
      "import": "./src/kernel.mjs",
      "default": "./src/kernel.mjs"
    },
    "./vfs": "./src/vfs.mjs",
    "./identity": "./src/authorization.mjs",
    "./authorization": "./src/authorization.mjs",
    "./leases": "./src/leases.mjs",
    "./idempotency": "./src/idempotency.mjs",
    "./events": "./src/events.mjs",
    "./projections": "./src/projections.mjs",
    "./ui": "./src/ui.mjs",
    "./http": "./src/http.mjs",
    "./guard": "./src/guard.mjs",
    "./conformance/fixtures.json": "./conformance/fixtures.json",
    "./conformance/reference-bundle.ucw.json": "./conformance/reference-bundle.ucw.json",
    "./registry/core.json": "./registry/core.json",
    "./package.json": "./package.json"
  },
  "bin": {
    "ssss": "scripts/ssss.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src",
    "types",
    "scripts",
    "registry",
    "conformance",
    "docs/ssss-spec.md",
    "docs/help",
    "skills/ssss",
    "VERSION",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "conformance": "node ./scripts/conformance.mjs conformance",
    "test": "node ./scripts/conformance.mjs conformance --engine"
  },
  "keywords": [
    "ssss",
    "agent",
    "okf",
    "markdown",
    "vault",
    "operation-contract",
    "ucw",
    "provisioning",
    "semantic-search",
    "multilingual",
    "generative-ui",
    "application-kernel"
  ],
  "author": "Greg Iteen",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gregiteen/ssss.git"
  },
  "homepage": "https://github.com/gregiteen/ssss#readme",
  "bugs": {
    "url": "https://github.com/gregiteen/ssss/issues"
  },
  "dependencies": {}
}
